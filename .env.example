# ─── Application ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://swipesmart:password@localhost:5432/swipesmart_db"

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
COOKIE_SECRET=change-this-to-a-long-random-string-in-production

# Admin endpoints are protected by this key (send as x-admin-api-key header)
ADMIN_API_KEY=change-this-to-a-strong-random-string

# ─── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list, or * for all origins (dev only)
CORS_ORIGIN=http://localhost:5173

# ─── LLM (Google Gemini) ───────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...

# ─── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_DAYS=30

# ─── Cache ─────────────────────────────────────────────────────────────────────
# How long card catalog stays cached in Redis (seconds)
CARD_CACHE_TTL=3600
