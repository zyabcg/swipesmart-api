{
  "name": "swipesmart-api",
  "version": "1.0.0",
  "description": "SwipeSmart Credit Card Recommendation Platform — REST API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node-dev --respawn --transpile-only -r dotenv/config src/server.ts",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "generate": "prisma generate",
    "typecheck": "tsc --noEmit",
    "scrape:cards": "ts-node --project scripts/scraper/tsconfig.json scripts/scraper/scrapeCards.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.22.0",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "nanoid": "^3.3.7",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
